# Make a copy of this example file and name it .env to automatically load
# these environment variables when running make

# Target hostname for deployment operations (e.g., the k3s cluster host)
# Note: Using REMOTE_HOST instead of HOST to avoid conflict with conda's HOST variable
REMOTE_HOST=your-hostname

# Cluster name identifier used for resource naming
CLUSTER=your-cluster-name

# SSH username for connecting to the target host via Ansible
ANSIBLE_REMOTE_USER=your-ssh-username

# Path to the Ansible inventory file containing target host definitions
ANSIBLE_INVENTORY_FILE=ansible/inventory.ini
